# Gruvbox Light theme for mako

font=IosevkaNerdFont 11
background-color=#fbf1c7ff
text-color=#3c3836ff
border-color=#d5c4a1ff
progress-color=#d79921ff

border-size=2
border-radius=8
padding=10
default-timeout=5000

# Icons

icons=1
max-icon-size=48

# Layout

width=300
height=100
margin=10

# Markup & formatting

markup=1
format=<b>%s</b>\n%b

# Colors for urgency levels

[urgency=low]
background-color=#fbf1c7ff
text-color=#3c3836ff
border-color=#d5c4a1ff

[urgency=normal]
background-color=#fbf1c7ff
text-color=#3c3836ff
border-color=#bdae93ff

[urgency=critical]
background-color=#cc241dff
text-color=#fbf1c7ff
border-color=#9d0006ff
default-timeout=0

